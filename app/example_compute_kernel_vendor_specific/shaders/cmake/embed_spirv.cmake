# Read a SPIR-V binary file and emit a self-contained .inl with a
# constexpr unsigned char[] + a length constant. Invoked via:
#   cmake -DSPV_IN=<path> -DSPV_OUT=<path> -DSYMBOL=<name> -P embed_spirv.cmake

if(NOT DEFINED SPV_IN OR NOT DEFINED SPV_OUT OR NOT DEFINED SYMBOL)
    message(FATAL_ERROR "embed_spirv.cmake requires SPV_IN, SPV_OUT, SYMBOL")
endif()

file(READ "${SPV_IN}" HEX_CONTENT HEX)
string(LENGTH "${HEX_CONTENT}" HEX_LEN)
math(EXPR BYTE_COUNT "${HEX_LEN} / 2")

set(ROWS "")
set(IDX 0)
set(LINE "")
while(IDX LESS HEX_LEN)
    string(SUBSTRING "${HEX_CONTENT}" ${IDX} 2 BYTE)
    if(LINE STREQUAL "")
        set(LINE "  0x${BYTE}")
    else()
        string(APPEND LINE ", 0x${BYTE}")
    endif()
    math(EXPR IDX "${IDX} + 2")
    math(EXPR POS "${IDX} / 2")
    math(EXPR LINEPOS "${POS} % 12")
    if(LINEPOS EQUAL 0 OR POS EQUAL BYTE_COUNT)
        if(NOT POS EQUAL BYTE_COUNT)
            string(APPEND LINE ",")
        endif()
        string(APPEND ROWS "${LINE}\n")
        set(LINE "")
    endif()
endwhile()

file(WRITE "${SPV_OUT}"
"// AUTOGENERATED at build time from ${SPV_IN}. DO NOT EDIT.
namespace example_vs_vulkan_shader {
constexpr unsigned char ${SYMBOL}_bytes[] = {
${ROWS}};
constexpr unsigned int ${SYMBOL}_bytes_len = ${BYTE_COUNT};
} // namespace example_vs_vulkan_shader
")
